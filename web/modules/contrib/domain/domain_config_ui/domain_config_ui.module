<?php

/**
 * @file
 * Allows saving of domain specific configuration through the UI.
 */

use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Hook\Attribute\LegacyHook;
use Drupal\domain_config_ui\Hook\DomainConfigUiFormHooks;

/**
 * Implements hook_form_alter().
 */
#[LegacyHook]
function domain_config_ui_form_alter(&$form, FormStateInterface $form_state, $form_id) {
  \Drupal::service(DomainConfigUiFormHooks::class)->formAlter($form, $form_state, $form_id);
}
