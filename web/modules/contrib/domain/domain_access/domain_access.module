/**
 * Creates our fields for an entity bundle.
 *
 * @param string $entity_type
 *   The entity type being created.
 * @param string $bundle
 *   The bundle being created.
 * @param array $text
 *   Optional text overrides keyed by entity type.
 *
 * @deprecated in domain:3.0.0 and is removed from domain:4.0.0.
 *   Use \Drupal\domain_access\DomainAccessHelperInterface::confirmFields().
 * @see https://www.drupal.org/project/domain/issues/3573820
 */
function domain_access_confirm_fields($entity_type, $bundle, array $text = []) {
  \Drupal::service('domain_access.helper')->confirmFields($entity_type, $bundle, $text);
}

/**
